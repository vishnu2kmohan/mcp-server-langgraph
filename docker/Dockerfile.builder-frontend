# Builder Frontend Dockerfile
# ===========================
# React frontend for the Visual Workflow Builder
# Multi-stage build: Node.js build -> nginx serve
#
# USAGE:
#   docker build -f docker/Dockerfile.builder-frontend -t builder-frontend \
#     --build-arg VITE_API_URL=http://localhost:8001 .
#   docker run -p 3000:8080 builder-frontend
#
# PORTS:
#   8080 - nginx HTTP (unprivileged port for non-root user)
#
# BUILD ARGS:
#   VITE_API_URL - Backend API URL (default: http://localhost:8001)

# ==============================================================================
# Stage 1: Build the React application
# ==============================================================================
FROM node:20-alpine AS builder

WORKDIR /app

# Copy package files
COPY src/mcp_server_langgraph/builder/frontend/package*.json ./

# Install dependencies
RUN npm ci --prefer-offline --no-audit

# Copy source code
COPY src/mcp_server_langgraph/builder/frontend/ ./

# Build argument for API URL
ARG VITE_API_URL=http://localhost:8001
ENV VITE_API_URL=${VITE_API_URL}

# Build the application
RUN npm run build

# ==============================================================================
# Stage 2: Serve with nginx
# ==============================================================================
FROM nginx:alpine

# Copy built assets from builder stage
COPY --from=builder /app/dist /usr/share/nginx/html

# Copy nginx configuration
COPY docker/nginx/builder.conf /etc/nginx/conf.d/default.conf

# Fix permissions for nginx user to run as non-root (DS002 compliance)
# Note: conf.d permissions needed for nginx entrypoint scripts (e.g., IPv6 setup)
RUN chown -R nginx:nginx /usr/share/nginx/html && \
    chown -R nginx:nginx /var/cache/nginx && \
    chown -R nginx:nginx /var/log/nginx && \
    chown -R nginx:nginx /etc/nginx/conf.d && \
    touch /var/run/nginx.pid && \
    chown -R nginx:nginx /var/run/nginx.pid

# Switch to non-root user
USER nginx

# Expose unprivileged port
EXPOSE 8080

# Health check
HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
    CMD wget --spider -q http://localhost:8080/ || exit 1

# Run nginx
CMD ["nginx", "-g", "daemon off;"]
